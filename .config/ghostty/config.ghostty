# --- Includes (Ghostty currently does NOT support include like kitty)
# You’ll need to manually merge hyde.conf + theme.conf



# --- Fonts
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 16
# --- Window / Appearance
window-padding-x = 2
window-padding-y = 2

background-opacity = 1.0
# background blur not supported (as of now)



# --- Cursor (VERY limited vs kitty)
# No cursor trail support in Ghostty
